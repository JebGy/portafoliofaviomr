---
import '../styles/global.css';
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />

    <title>Favio Gabriel Munayco Rivera — Full-Stack Developer & CEO @ ApexCorp</title>
    <meta name="description" content="Full-Stack Developer especializado en soluciones B2B, arquitecturas Cloud y automatización de procesos corporativos. CEO de ApexCorp S.A.C." />
    <meta name="author" content="Favio Gabriel Munayco Rivera" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://favio.munayco.dev/" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://favio.munayco.dev/" />
    <meta property="og:title" content="Favio Gabriel Munayco Rivera — Full-Stack Developer & CEO @ ApexCorp" />
    <meta property="og:description" content="Full-Stack Developer especializado en soluciones B2B, arquitecturas Cloud y automatización de procesos corporativos. CEO de ApexCorp S.A.C." />
    <meta property="og:locale" content="es_PE" />
    <meta property="og:site_name" content="Favio Munayco" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Favio Gabriel Munayco Rivera — Full-Stack Developer & CEO @ ApexCorp" />
    <meta name="twitter:description" content="Full-Stack Developer especializado en soluciones B2B, arquitecturas Cloud y automatización de procesos corporativos. CEO de ApexCorp S.A.C." />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Inter:wght@200;300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Favio Gabriel Munayco Rivera",
        "jobTitle": "Full-Stack Developer & CEO",
        "worksFor": {
          "@type": "Organization",
          "name": "ApexCorp S.A.C.",
          "url": "https://apexcorpsac.com"
        },
        "url": "https://favio.munayco.dev",
        "sameAs": [
          "https://www.linkedin.com/in/favio-munayco/",
          "https://github.com"
        ],
        "knowsAbout": ["Full-Stack Development", "Cloud Architecture", "B2B Solutions", "AI Integration", "DevOps"],
        "description": "Full-Stack Developer especializado en soluciones B2B, arquitecturas Cloud y automatización de procesos corporativos."
      }
    </script>
  </head>
  <body>
    <slot />

    <div class="cursor-trail" data-trail="0" style="width:14px;height:14px;"></div>
    <div class="cursor-trail" data-trail="1" style="width:11px;height:11px;opacity:.85;"></div>
    <div class="cursor-trail" data-trail="2" style="width:9px;height:9px;opacity:.7;"></div>
    <div class="cursor-trail" data-trail="3" style="width:7px;height:7px;opacity:.55;"></div>
    <div class="cursor-trail" data-trail="4" style="width:5px;height:5px;opacity:.4;"></div>
    <div class="cursor-main"></div>
    <div class="cursor-dot"></div>

    <div class="page-transition">
      <div class="page-transition-bar"></div>
      <div class="page-transition-bar"></div>
      <div class="page-transition-bar"></div>
      <div class="page-transition-bar"></div>
      <div class="page-transition-bar"></div>
    </div>

    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      // ============ Custom cursor ============
      const trails = Array.from(document.querySelectorAll<HTMLElement>('.cursor-trail'));
      const cursorMain = document.querySelector<HTMLElement>('.cursor-main');
      const cursorDot = document.querySelector<HTMLElement>('.cursor-dot');

      let mouseX = window.innerWidth / 2;
      let mouseY = window.innerHeight / 2;
      const trailPos = trails.map(() => ({ x: mouseX, y: mouseY }));

      // Initial placement so they appear before first move
      if (cursorMain) cursorMain.style.transform = `translate(${mouseX - 20}px, ${mouseY - 20}px)`;
      if (cursorDot) cursorDot.style.transform = `translate(${mouseX - 3}px, ${mouseY - 3}px)`;

      window.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
        if (cursorMain) gsap.to(cursorMain, { x: mouseX - 20, y: mouseY - 20, duration: 0.35, ease: 'power3.out' });
        if (cursorDot)  gsap.to(cursorDot,  { x: mouseX - 3,  y: mouseY - 3,  duration: 0.08, ease: 'power3.out' });
      });

      function trailLoop() {
        let tx = mouseX, ty = mouseY;
        trails.forEach((el, i) => {
          const speed = 0.22 - i * 0.03;
          trailPos[i].x += (tx - trailPos[i].x) * speed;
          trailPos[i].y += (ty - trailPos[i].y) * speed;
          const w = el.offsetWidth / 2;
          const h = el.offsetHeight / 2;
          el.style.transform = `translate(${trailPos[i].x - w}px, ${trailPos[i].y - h}px)`;
          tx = trailPos[i].x;
          ty = trailPos[i].y;
        });
        requestAnimationFrame(trailLoop);
      }
      trailLoop();

      // Hover state on interactive elements
      const interactiveSel = 'a, button, [data-cursor-hover], input, textarea, select';
      document.addEventListener('mouseover', (e) => {
        const t = e.target as HTMLElement;
        if (t.closest && t.closest(interactiveSel)) {
          cursorMain?.classList.add('hover');
          cursorDot?.classList.add('hover');
        }
      });
      document.addEventListener('mouseout', (e) => {
        const t = e.target as HTMLElement;
        if (t.closest && t.closest(interactiveSel)) {
          cursorMain?.classList.remove('hover');
          cursorDot?.classList.remove('hover');
        }
      });

      // ============ Page enter transition ============
      gsap.fromTo('.page-transition-bar',
        { scaleY: 1 },
        { scaleY: 0, duration: 0.9, stagger: 0.06, ease: 'power3.inOut', delay: 0.1 }
      );

      // ============ Hero char animation ============
      gsap.from('.char', {
        y: 80,
        opacity: 0,
        rotateX: -90,
        duration: 0.9,
        ease: 'back.out(1.4)',
        stagger: 0.025,
        delay: 0.5
      });

      // ============ Generic reveal on scroll ============
      gsap.utils.toArray<HTMLElement>('.reveal').forEach((el) => {
        gsap.fromTo(el,
          { y: 60, opacity: 0 },
          {
            y: 0, opacity: 1, duration: 0.9, ease: 'power3.out',
            scrollTrigger: { trigger: el, start: 'top 85%' }
          }
        );
      });

      // ============ Magnetic buttons ============
      document.querySelectorAll<HTMLElement>('.magnetic-btn').forEach((btn) => {
        const child = btn.querySelector<HTMLElement>(':scope > *');
        if (!child) return;
        btn.addEventListener('mousemove', (e) => {
          const rect = btn.getBoundingClientRect();
          const x = e.clientX - rect.left - rect.width / 2;
          const y = e.clientY - rect.top - rect.height / 2;
          gsap.to(child, { x: x * 0.25, y: y * 0.25, duration: 0.4, ease: 'power3.out' });
        });
        btn.addEventListener('mouseleave', () => {
          gsap.to(child, { x: 0, y: 0, duration: 0.5, ease: 'elastic.out(1, 0.5)' });
        });
      });
    </script>
  </body>
</html>
